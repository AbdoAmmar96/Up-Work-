# Base URL of the Laravel API. Leave as /api in dev (proxied by Vite to localhost:8000).
# In production point it at your deployed API, e.g. https://api.upwork-eg.com/api
VITE_API_URL=/api

# Public site URL (used to build absolute OG/sitemap URLs). Set before `npm run build`.
VITE_SITE_URL=https://upwork-eg.com

# Optional analytics — leave empty to disable.
VITE_GA_ID=
VITE_FB_PIXEL=
