# SPA routing للدّاشبورد — مقدّم من مجلد فرعي /dashboard/
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /dashboard/

  # ملفات وفولدرات موجودة فعلاً تُخدّم زي ما هي
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # أي حاجة تانية → index.html بتاع الدّاشبورد
  RewriteRule ^ /dashboard/index.html [L]
</IfModule>

# الدّاشبورد خاص — امنع الفهرسة
<IfModule mod_headers.c>
  Header set X-Robots-Tag "noindex, nofollow"
</IfModule>
