# ===== UP Work API — .env للإنتاج (Hostinger) =====
# انسخ محتواه إلى ملف اسمه .env داخل مجلد الـ API على السيرفر، وعدّل القيم.

APP_NAME="UP Work"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://upworkeg.com/api

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en

# ===== قاعدة البيانات =====
# اعملها من hPanel → Databases → MySQL، وحط بياناتها هنا
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=u393186285_upwork
DB_USERNAME=u393186285_upwork
DB_PASSWORD=ضع_الباسورد_هنا

FILESYSTEM_DISK=public

# ===== CORS — روابط الواجهات المسموح لها تكلّم الـ API =====
# لازم بدون / في الآخر، مفصولة بفاصلة
FRONTEND_URLS=https://upworkeg.com,https://www.upworkeg.com

SANCTUM_STATEFUL_DOMAINS=upworkeg.com,www.upworkeg.com

# على Shared hosting الأفضل file بدل database عشان الأداء
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

LOG_CHANNEL=stack
LOG_LEVEL=error

# ===== الإيميل (لاستقبال رسائل التواصل) — من hPanel → Emails =====
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=no-reply@upworkeg.com
MAIL_PASSWORD=ضع_باسورد_الإيميل
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=no-reply@upworkeg.com
MAIL_FROM_NAME="UP Work"
