APP_NAME="UP Work"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://upwork-api.test

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en

# Database (set these to your Herd MySQL credentials)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=upwork
DB_USERNAME=root
DB_PASSWORD=

FILESYSTEM_DISK=public

# Front-end origins allowed to call the API (CORS) — comma separated, no trailing slash
FRONTEND_URLS=http://localhost:5173,http://localhost:5174

# Sanctum (only needed if you later switch the dashboard to cookie-based SPA auth)
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:5174

CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database
